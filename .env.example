# ─────────────────────────────────────────────────────────────
#  Bloomy — variables d'environnement
#  Copiez ce fichier en `.env.local` et remplissez les valeurs.
#  Le site fonctionne SANS Supabase (mode démo avec données locales),
#  mais pour enregistrer de vraies commandes, configurez Supabase.
# ─────────────────────────────────────────────────────────────

# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé "service_role" (secret, côté serveur uniquement — NE JAMAIS exposer au client)
SUPABASE_SERVICE_ROLE_KEY=

# Mot de passe du super admin (/admin). Changez-le impérativement en production.
ADMIN_PASSWORD=bloomy-admin

# Secret pour signer le cookie de session admin (chaîne aléatoire longue).
ADMIN_SESSION_SECRET=change-me-to-a-long-random-string

# URL publique du site (utilisée dans les métadonnées + QR codes). Ex: https://bloomy.tn
# IMPORTANT : à définir sur le vrai domaine en production (sinon les liens
# canoniques pointent vers localhost).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# NB : le téléphone et l'email de contact ne sont PLUS des variables d'env.
# Ils se gèrent désormais depuis le super admin → /admin/parametres (section
# « Contact »), stockés dans la table `settings`.
